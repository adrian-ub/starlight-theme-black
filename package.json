{
  "name": "starlight-theme-black-monorepo",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@11.1.1",
  "description": "Starlight theme inspired by Shadcn docs",
  "author": "adrian-ub",
  "license": "MIT",
  "homepage": "https://github.com/adrian-ub/starlight-theme-black",
  "repository": {
    "type": "git",
    "url": "https://github.com/adrian-ub/starlight-theme-black.git"
  },
  "bugs": "https://github.com/adrian-ub/starlight-theme-black/issues",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "lint": "eslint .",
    "release": "bumpp && npm publish",
    "prepare": "simple-git-hooks",
    "docs": "nr -C docs dev",
    "docs:build": "nr -C docs build"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.1",
    "@astrojs/starlight": "^0.38.1",
    "astro": "^6.0.4",
    "astro-eslint-parser": "^1.2.2",
    "bumpp": "^10.3.2",
    "eslint": "^9.39.2",
    "eslint-plugin-astro": "^1.5.0",
    "eslint-plugin-format": "^1.1.0",
    "lint-staged": "^16.2.7",
    "prettier-plugin-astro": "^0.14.1",
    "simple-git-hooks": "^2.13.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
