---
import { getNavLinks } from '../libs/navbar'

const currentPath = Astro.url.pathname
const navLinks = getNavLinks(Astro.currentLocale)
---

<nav class="nav-bar">
  {
    navLinks.map((nav) => (
      <a class:list={[{ active: currentPath === nav.link }]} href={nav.link} {...nav.attrs}>
        {nav.label}
        {nav.badge && <span class="new-dot" />}
      </a>
    ))
  }
</nav>

<style>
  .nav-bar {
    font-size: 0.875rem;
    line-height: 1.25rem;
    align-items: center;
    display: none;
  }

  @media (min-width: 1024px) {
    .nav-bar {
      display: flex;
      gap: 0.375rem;
    }
  }

  .nav-bar a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 500;
    min-height: 2rem;
    padding: 0 0.625rem;
    border-radius: calc(var(--radius) - 2px);
    text-decoration: none;
    transition-property: color, background-color, border-color, text-decoration-color, fill, stroke;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 0.15s;
    color: var(--foreground);
    position: relative;
  }

  .nav-bar a:hover {
    color: var(--accent-foreground);
    background-color: color-mix(in oklab, var(--accent) 80%, transparent);
  }

  .new-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #3b82f6;
    margin-left: calc(var(--spacing) * 1.5);
    flex-shrink: 0;
  }
</style>
