---
import { getNavLinks } from '../libs/navbar'
const { sidebar } = Astro.locals.starlightRoute

const currentPath = Astro.url.pathname
const navLinks = getNavLinks(Astro.currentLocale)
---

<div class="mobile-nav">
  <div class="mobile-nav-content">
    <div class="mobile-nav-section">
      <div class="mobile-nav-label">{Astro.locals.t('menuButton.accessibleLabel')}</div>
      <div class="mobile-nav-links">
        {
          navLinks.map((nav) => (
            <a href={nav.link} {...nav.attrs}>
              {nav.label}
              {nav.badge && <span class="new-dot" />}
            </a>
          ))
        }
      </div>
    </div>

    {
      sidebar.map(
        (entry) =>
          entry.type !== 'link' && (
            <div class="mobile-nav-section">
              <div class="mobile-nav-label">{entry.label}</div>
              <div class="mobile-nav-links">
                {entry.entries.map(
                  (link) =>
                    link.type === 'link' && (
                      <a href={link.href} {...link.attrs} data-active={currentPath === link.href}>
                        {link.label}
                      </a>
                    ),
                )}
              </div>
            </div>
          ),
      )
    }
  </div>
</div>

<style>
  :global(html[data-mobile-menu-expanded]),
  :global(body[data-mobile-menu-expanded]) {
    overflow: hidden;
    height: 100%;
  }

  :global([data-mobile-menu-expanded]) {
    --black-menu-visibility: visible;
  }

  .mobile-nav {
    visibility: var(--black-menu-visibility, hidden);
    display: flex;
    position: fixed;
    top: var(--sl-nav-height);
    left: 0;
    right: 0;
    bottom: 0;
    z-index: calc(var(--sl-z-index-navbar) + 2);
    background-color: color-mix(in oklab, var(--background) 90%, transparent);
    backdrop-filter: blur(8px);
    flex-direction: column;
    justify-content: flex-start;
  }

  .mobile-nav-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    overflow-y: auto;
    padding: 1.5rem;
    height: 100%;
  }

  .mobile-nav-content::-webkit-scrollbar {
    width: 0;
  }

  .mobile-nav-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .mobile-nav-label {
    font-size: 0.875rem;
    line-height: 1.25rem;
    font-weight: 500;
    color: var(--muted-foreground);
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .mobile-nav-links a {
    font-size: 1.25rem;
    line-height: 1.75rem;
    font-weight: 500;
    color: var(--foreground);
    text-decoration: inherit;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .new-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #3b82f6;
    margin-left: calc(var(--spacing) * 1.5);
    flex-shrink: 0;
  }
</style>
