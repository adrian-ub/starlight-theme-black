---
import MobileNav from './MobileNav.astro'
---

<black-menu-button class="print:hidden">
  <button class="sl-flex md:sl-hidden" aria-expanded="false" aria-controls="starlight__sidebar">
    <div class="hamburger">
      <span class="bar bar-1"></span>
      <span class="bar bar-2"></span>
    </div>
    <span class="label">{Astro.locals.t('menuButton.accessibleLabel')}</span>
    <span class="sr-only">{Astro.locals.t('menuButton.accessibleLabel')}</span>
  </button>
</black-menu-button>

<MobileNav />

<script>
  class BlackMenuButton extends HTMLElement {
    btn = this.querySelector('button')!

    constructor() {
      super()
      this.btn.addEventListener('click', () => this.toggleExpanded())

      const parentNav = this.closest('nav')
      if (parentNav) {
        parentNav.addEventListener('keyup', (e) => this.closeOnEscape(e))
      }

      matchMedia('(min-width: 50em)').addEventListener('change', () => this.setExpanded(false))
    }

    setExpanded(expanded: boolean) {
      this.btn.setAttribute('aria-expanded', String(expanded))
      document.body.toggleAttribute('data-mobile-menu-expanded', expanded)
      document.querySelectorAll<HTMLElement>('.main-frame, .sl-skip-link').forEach((el) => {
        el.toggleAttribute('inert', expanded)
      })
    }

    toggleExpanded() {
      this.setExpanded(this.btn.getAttribute('aria-expanded') !== 'true')
    }

    closeOnEscape(e: KeyboardEvent) {
      if (e.code === 'Escape') {
        this.setExpanded(false)
        this.btn.focus()
      }
    }
  }

  customElements.define('black-menu-button', BlackMenuButton)
</script>

<style>
  button {
    all: unset;
    display: inline-flex;
    cursor: pointer;
    align-items: center;
    gap: 0.5rem;
    margin-right: calc(var(--spacing) * 2);
    margin-left: calc(var(--spacing) * -2);
    height: 2rem;
    padding: 0 0.5rem;
    font-size: 0.875rem;
    line-height: 1.25rem;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    border-radius: calc(var(--radius) - 2px);
    transition: background-color 0.15s ease;

    @media (min-width: 50rem) {
      display: none;
    }
  }

  .hamburger {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1rem;
    height: 1rem;
  }

  .bar {
    display: block;
    position: absolute;
    left: 0;
    width: calc(var(--spacing) * 4);
    height: calc(var(--spacing) * 0.5);
    background-color: var(--foreground);
    border-radius: 1px;
    transition:
      top 100ms ease-out,
      transform 100ms ease-out;
  }

  /* Closed state: two parallel lines */
  .bar-1 {
    top: calc(var(--spacing) * 1);
  }

  .bar-2 {
    top: calc(var(--spacing) * 2.5);
  }

  /* Open state: both centered + rotated to form X */
  button[aria-expanded='true'] .bar-1 {
    top: 50%;
    transform: translateY(-50%) rotate(45deg);
  }

  button[aria-expanded='true'] .bar-2 {
    top: 50%;
    transform: translateY(-50%) rotate(-45deg);
  }

  .label {
    font-weight: 500;
  }
</style>
