---

<button class="mobile-menu-toggle" aria-expanded="false" aria-controls="starlight__sidebar">
  <div class="hamburger">
    <span class="bar bar-1"></span>
    <span class="bar bar-2"></span>
  </div>
  <span class="label">{Astro.locals.t('menuButton.accessibleLabel')}</span>
  <span class="sr-only">{Astro.locals.t('menuButton.accessibleLabel')}</span>
</button>

<style>
  button {
    all: unset;
    display: inline-flex;
    cursor: pointer;
    align-items: center;
    gap: 0.5rem;
    margin-right: calc(var(--spacing) * 2);
    margin-left: calc(var(--spacing) * -2);
    height: 2rem;
    padding: 0 0.5rem;
    font-size: 0.875rem;
    line-height: 1.25rem;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    border-radius: calc(var(--radius) - 2px);
    transition: background-color 0.15s ease;
  }

  button:hover {
    background-color: color-mix(in oklab, var(--accent) 80%, transparent);
  }

  @media (min-width: 1024px) {
    button {
      display: none;
    }
  }

  .hamburger {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1rem;
    height: 1rem;
  }

  .bar {
    display: block;
    position: absolute;
    left: 0;
    width: 1rem;
    height: 2px;
    background-color: var(--foreground);
    border-radius: 1px;
    transition:
      top 100ms ease-out,
      transform 100ms ease-out;
  }

  /* Closed state: two parallel lines */
  .bar-1 {
    top: 3px;
  }

  .bar-2 {
    top: 9px;
  }

  /* Open state: both centered + rotated to form X */
  button[aria-expanded='true'] .bar-1 {
    top: 50%;
    transform: translateY(-50%) rotate(45deg);
  }

  button[aria-expanded='true'] .bar-2 {
    top: 50%;
    transform: translateY(-50%) rotate(-45deg);
  }

  .label {
    font-weight: 500;
  }
</style>

<script>
  function initMobileMenuToggle() {
    const toggle = document.querySelector('.mobile-menu-toggle') as HTMLButtonElement | null
    const sidebar = document.getElementById('starlight__sidebar') as HTMLElement | null
    if (!toggle || !sidebar) return

    const setExpanded = (expanded: boolean) => {
      toggle.setAttribute('aria-expanded', String(expanded))
      sidebar.setAttribute('aria-expanded', String(expanded))
      document.documentElement.style.overflow = expanded ? 'hidden' : ''
    }

    toggle.addEventListener('click', () => {
      const isExpanded = toggle.getAttribute('aria-expanded') === 'true'
      setExpanded(!isExpanded)
    })

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
        setExpanded(false)
        toggle.focus()
      }
    })

    matchMedia('(min-width: 1024px)').addEventListener('change', (e) => {
      if (e.matches) setExpanded(false)
    })
  }

  initMobileMenuToggle()
  document.addEventListener('astro:after-swap', initMobileMenuToggle)
</script>
