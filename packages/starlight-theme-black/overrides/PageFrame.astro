---
import MobileMenuToggle from './MobileMenuToggle.astro'
import MobileNav from '../components/MobileNav.astro'
import { markdownToHtml } from 'satteri'
import userConfig from 'virtual:starlight-theme-black-config'

const { hasSidebar } = Astro.locals.starlightRoute

const footerContent = markdownToHtml(userConfig.footerText, { features: { frontmatter: false, gfm: true } })
---

<div data-slot="layout">
  <header>
    <slot name="header" />
  </header>

  {
    hasSidebar && (
      <nav class="sidebar print:hidden">
        <MobileMenuToggle />
        <div id="starlight__sidebar" class="sidebar-pane">
          <MobileNav class="mobile-sidebar" />
          <div class="sidebar-content desktop-sidebar">
            <slot name="sidebar" />
          </div>
        </div>
      </nav>
    )
  }

  <div class="main-frame"><slot /></div>

  <footer>
    <div data-slot="footer-text" set:html={footerContent.html} />
  </footer>
</div>

<style>
  [data-slot='layout'] {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    min-height: 100svh;
    background: var(--background);
  }

  header {
    position: sticky;
    top: 0;
    z-index: 50;
    width: 100%;
    background: var(--background);
    padding-inline: calc(var(--spacing) * 6);
    display: flex;
    height: var(--header-height);
    align-items: center;
  }

  .sidebar {
    display: contents;
  }

  .sidebar-pane {
    visibility: hidden;
    position: fixed;
    inset-block: var(--header-height) 0;
    inset-inline-start: 0;
    width: 100%;
    z-index: 40;
    overflow-y: auto;
    scrollbar-gutter: stable;
    background: color-mix(in oklab, var(--background) 90%, transparent);
    backdrop-filter: blur(8px);
  }

  .sidebar-pane[aria-expanded='true'] {
    visibility: visible;
  }

  .mobile-sidebar {
    display: block;
  }

  .desktop-sidebar {
    display: none;
  }

  @media (min-width: 1024px) {
    .sidebar-pane {
      visibility: visible;
      width: var(--sidebar-width);
      background: var(--background);
      backdrop-filter: none;
    }

    .mobile-sidebar {
      display: none;
    }

    .desktop-sidebar {
      display: flex;
      height: 100%;
      min-height: max-content;
      flex-direction: column;
    }

    .main-frame {
      padding-inline-start: var(--sidebar-width);
    }
  }

  .main-frame {
    width: 100%;
    max-width: 1024px;
    margin-inline: auto;
  }

  [data-slot='layout']:has(.sidebar) .main-frame {
    max-width: none;
  }

  > footer {
    border-top: none;
    height: 6rem;
    display: flex;
    align-items: center;

    [data-slot='footer-text'] {
      width: 100%;
      max-width: var(--container-max-width);
      margin-inline: auto;
      padding-inline: calc(var(--spacing) * 6);
      font-size: 0.875rem;
      line-height: 1.25rem;
      color: var(--muted-foreground);
      text-wrap: balance;
      text-align: center;
    }

    &:is(:where(body):has(*[data-slot='docs']) *) {
      display: none;
    }

    &:is(:where(body):has(.docs-nav)) {
      padding-bottom: calc(var(--spacing) * 20);

      @media (min-width: 640px) {
        padding-bottom: 0;
      }
    }

    &:is(:where(body):has(.section-soft)) {
      background: var(--surface-40);
    }

    &:is(:where(body):has(*[data-slot='designer']) *) {
      display: none;
    }
  }
</style>
