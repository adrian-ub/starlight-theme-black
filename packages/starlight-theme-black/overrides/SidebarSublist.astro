---
import type { StarlightRouteData } from '@astrojs/starlight/route-data'

interface Props {
  sublist: StarlightRouteData['sidebar']
  nested?: boolean
}

const { sublist } = Astro.props
---

{
  sublist.map((entry, index) =>
    entry.type === 'link' ? (
      <a
        href={entry.href}
        aria-current={entry.isCurrent && 'page'}
        class:list={['entry-link', entry.attrs.class]}
        {...entry.attrs}
      >
        <span class="entry-link-inner" />
        {entry.label}
        {entry.badge && <span class="entry-badge" />}
      </a>
    ) : (
      <div class={`container-sidebar-entry ${index === 0 && !Astro.props.nested ? ' first' : ''}`}>
        <div class="entry-title">{entry.label}</div>
        <div class="container-group-link">
          <Astro.self sublist={entry.entries} nested />
        </div>
      </div>
    ),
  )
}

<style>
  .container-sidebar-entry {
    padding: calc(var(--spacing) * 2);
    flex-direction: column;
    min-width: 0;
    width: 100%;
    display: flex;
    position: relative;
  }

  .container-sidebar-entry.first {
    padding-top: calc(var(--spacing) * 12);
  }

  .entry-title {
    color: var(--muted-foreground);
    font-weight: 500;
    font-size: 0.75rem;
    line-height: calc(1 / 0.75);
    padding-inline: calc(var(--spacing) * 2);
    border-radius: calc(var(--radius) * 0.8);
    display: flex;
    align-items: center;
    height: calc(var(--spacing) * 8);
  }

  .container-group-link {
    font-size: 0.875rem;
    line-height: 1.25rem;
    gap: 2px;
    grid-auto-rows: max-content;
    grid-auto-flow: row;
    display: grid;
    width: 100%;
  }

  .entry-link {
    text-decoration: none;
    font-weight: 500;
    font-size: 0.8rem;
    text-align: left;
    padding: calc(var(--spacing) * 2);
    border-radius: calc(var(--radius) * 0.8);
    gap: calc(var(--spacing) * 2);
    align-items: center;
    width: fit-content;
    height: 30px;
    display: flex;
    position: relative;
    color: var(--foreground);
  }

  .entry-link[aria-current='page'] {
    color: var(--sidebar-accent-foreground);
    font-weight: 500;
    background-color: var(--accent);
  }

  .entry-link > .entry-link-inner {
    width: calc(var(--spacing) * 56);
    inset: 0;
    position: absolute;
  }

  .entry-badge {
    width: calc(var(--spacing) * 2);
    height: calc(var(--spacing) * 2);
    border-radius: 50%;
    background: #3b82f6;
    flex-shrink: 0;
  }
</style>
