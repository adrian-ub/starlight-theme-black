---
import { Icon } from '@astrojs/starlight/components'
import { PAGE_TITLE_ID } from '../constants'
import userConfig from 'virtual:starlight-theme-black-config'
import { Dropdown, DropdownContent, DropdownItem, DropdownTrigger } from '../components/custom/dropdown'

import LinkButton from '../components/LinkButton.astro'
const {
  entry: { data, body },
  pagination: { prev, next },
} = Astro.locals.starlightRoute

const { title, description } = data
const includeAIMenu = userConfig.docs?.includeAiUtilities ?? true

const pageUrl = Astro.url.href
const aiPromptTemplate = userConfig.docs.aiPrompt
const aiPrompt = aiPromptTemplate.replace(/\{url\}/g, pageUrl)
const encodedPrompt = encodeURIComponent(aiPrompt)
const aiServices = userConfig.docs.aiServices
---

<div data-slot="doc-title">
  <div data-slot="doc-title-header">
    <h1 id={PAGE_TITLE_ID}>{title}</h1>

    <div data-slot="doc-title-actions">
      {
        includeAIMenu && (
          <div style="display: flex; align-items: center; background-color: var(--secondary); border-radius: var(--radius);">
            <LinkButton
              class="copy-page-action"
              variant="secondary"
              data-content={`
---
title: ${title}
description: ${description}
---
${body}`.trim()}
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect width="14" height="14" x="8" y="8" rx="2" ry="2" />
                <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
              </svg>
              Copy page
            </LinkButton>
            {aiServices.length > 0 && (
              <Dropdown>
                <DropdownTrigger variant="secondary" size="sm">
                  <Icon name="down-caret" size="1rem" />
                </DropdownTrigger>
                <DropdownContent align="end">
                  {aiServices.map((service) => (
                    <DropdownItem
                      as="a"
                      href={service.url.replace(/\{prompt\}/g, encodedPrompt)}
                      target="_blank"
                      rel="noopener"
                    >
                      <Fragment set:html={service.icon} />
                      {service.name}
                    </DropdownItem>
                  ))}
                </DropdownContent>
              </Dropdown>
            )}
          </div>
        )
      }

      {
        prev && (
          <LinkButton size="icon-md" variant="secondary" href={prev.href}>
            <Icon name="left-arrow" />
          </LinkButton>
        )
      }

      {
        next && (
          <LinkButton size="icon-md" variant="secondary" href={next.href}>
            <Icon name="right-arrow" />
          </LinkButton>
        )
      }
    </div>
  </div>

  {description && <p slot="doc-title-description">{description}</p>}
</div>

<script>
  function initCopyPage() {
    document.querySelectorAll('.copy-page-action').forEach((item) => {
      item.addEventListener('click', (e) => {
        e.preventDefault()
        const content = (item as HTMLElement).dataset.content
        if (content) {
          navigator.clipboard.writeText(content).then(() => {
            const original = item.innerHTML
            item.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg> Copy page`
            setTimeout(() => {
              item.innerHTML = original
            }, 2000)
          })
        }
      })
    })
  }

  initCopyPage()
  document.addEventListener('astro:after-swap', initCopyPage)
</script>

<style>
  div[data-slot='doc-title'] {
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 2);
  }

  [data-slot='doc-title-header'] {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: calc(var(--spacing) * 2);

    @media (min-width: 640px) {
      align-items: start;
    }

    h1 {
      letter-spacing: var(--tracking-tight);
      font-weight: 600;
      font-size: 1.875rem;
      line-height: 2.25rem;
      scroll-margin: 5rem;
      margin: 0;
      color: var(--foreground);
    }

    [data-slot='doc-title-actions'] {
      position: relative;
      display: flex;
      align-items: center;
      gap: calc(var(--spacing) * 2);
    }
  }

  [slot='doc-title-description'] {
    margin: 0;
    color: var(--muted-foreground);
    font-size: 1rem;
    line-height: 1.75rem;
    text-wrap: balance;

    @media (min-width: 640px) {
      max-width: 80%;
    }
  }
</style>
