---
import { Icon } from '@astrojs/starlight/components'
import { PAGE_TITLE_ID } from '../constants'
import userConfig from 'virtual:starlight-theme-black-config'
import { resolveMarkdownActions } from '../libs/config'
import type { MarkdownActionsFrontmatter } from '../schemas/markdown-actions'

const {
  entry: { data, body },
  pagination: { prev, next },
} = Astro.locals.starlightRoute

const { title, description } = data

const frontmatterConfig = (data as any).showMarkdownActions as MarkdownActionsFrontmatter | undefined
const resolved = resolveMarkdownActions(userConfig.docs ?? {}, frontmatterConfig)

const pageUrl = Astro.url.href
const aiPrompt = resolved.prompt.replace(/\{url\}/g, pageUrl)
const encodedPrompt = encodeURIComponent(aiPrompt)
const aiServices = resolved.services
const copyButtonContent = `---\ntitle: ${title}\ndescription: ${description}\n---\n\n${body}`.trim()
---

<div data-slot="doc-title">
  <div data-slot="doc-title-header">
    <h1 id={PAGE_TITLE_ID}>{title}</h1>

    <div class="docs-nav">
      {
        resolved.enabled && (
          <div class="copy-page-group">
            <button class="copy-page-action" data-content={copyButtonContent}>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect width="14" height="14" x="8" y="8" rx="2" ry="2" />
                <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
              </svg>
              Copy page
            </button>
            {aiServices.length > 0 && (
              <>
                <div class="copy-page-separator" />
                <div class="copy-page-dropdown">
                  <button class="copy-page-dropdown-trigger" type="button" aria-expanded="false" aria-haspopup="true">
                    <Icon name="down-caret" size="1rem" />
                  </button>
                  <div class="ai-services-menu" role="menu">
                    <div class="ai-services-content">
                      {aiServices.map((service) => (
                        <a
                          class="ai-service-item"
                          href={service.url.replace(/\{prompt\}/g, encodedPrompt)}
                          target="_blank"
                          rel="noopener"
                          role="menuitem"
                        >
                          <Fragment set:html={service.icon} />
                          <span>{service.name}</span>
                        </a>
                      ))}
                    </div>
                  </div>
                </div>
              </>
            )}
          </div>
        )
      }

      <div class="nav-buttons">
        {
          prev && (
            <a href={prev.href}>
              <Icon name="left-arrow" />
            </a>
          )
        }
        {
          next && (
            <a href={next.href}>
              <Icon name="right-arrow" />
            </a>
          )
        }
      </div>
    </div>
  </div>

  {description && <p class="doc-title-description">{description}</p>}
</div>

<script>
  function initCopyPage() {
    document.querySelectorAll('.copy-page-action').forEach((item) => {
      item.addEventListener('click', (e) => {
        e.preventDefault()
        const content = (item as HTMLElement).dataset.content
        if (content) {
          navigator.clipboard.writeText(content).then(() => {
            const original = item.innerHTML
            item.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg> Copy page`
            setTimeout(() => {
              item.innerHTML = original
            }, 2000)
          })
        }
      })
    })

    document.querySelectorAll('.copy-page-dropdown').forEach((dropdown) => {
      const trigger = dropdown.querySelector('.copy-page-dropdown-trigger') as HTMLButtonElement
      const menu = dropdown.querySelector('.ai-services-menu') as HTMLElement
      if (!trigger || !menu) return

      trigger.addEventListener('click', (e) => {
        e.stopPropagation()
        const isOpen = menu.classList.contains('open')
        menu.classList.toggle('open')
        trigger.setAttribute('aria-expanded', String(!isOpen))
      })

      document.addEventListener('click', (e) => {
        if (!dropdown.contains(e.target as Node)) {
          menu.classList.remove('open')
          trigger.setAttribute('aria-expanded', 'false')
        }
      })

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          menu.classList.remove('open')
          trigger.setAttribute('aria-expanded', 'false')
          trigger.focus()
        }
      })
    })
  }

  initCopyPage()
  document.addEventListener('astro:after-swap', initCopyPage)
</script>

<style>
  .copy-page-action,
  .copy-page-dropdown-trigger {
    all: unset;
    display: inline-flex;
    padding-left: 0.75rem;
    padding-right: 0.75rem;
    shrink: 0;
    gap: calc(var(--spacing) * 1.5);
    justify-content: center;
    align-items: center;
    outline-style: none;
    height: 2rem;
    font-size: 0.875rem;
    line-height: calc(1.25 / 0.875);
    font-weight: 500;
    white-space: nowrap;
    padding-inline: calc(var(--spacing) * 2.5);
    height: calc(var(--spacing) * 8);

    color: var(--secondary-foreground);
    white-space: nowrap;

    @media (min-width: 48rem) {
      font-size: 0.8rem;
    }

    @media (min-width: 48rem) {
      height: calc(var(--spacing) * 7);
    }
  }

  a {
    color: var(--secondary-foreground);
    text-decoration: inherit;
    background-color: var(--secondary);
    border-radius: calc(var(--radius) * 0.8);
    justify-content: center;
    gap: calc(var(--spacing) * 2);
    align-items: center;
    flex-shrink: 0;
    display: inline-flex;
    width: calc(var(--spacing) * 8);
    height: calc(var(--spacing) * 8);

    @media (min-width: 48rem) {
      width: calc(var(--spacing) * 7);
      height: calc(var(--spacing) * 7);
    }
  }

  [data-slot='doc-title'] {
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 2);
  }

  [data-slot='doc-title-header'] {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: calc(var(--spacing) * 2);

    @media (min-width: 768px) {
      align-items: flex-start;
    }

    h1 {
      letter-spacing: var(--tracking-tight);
      font-weight: 600;
      font-size: 1.875rem;
      line-height: 2.25rem;
      scroll-margin: 5rem;
      margin: 0;
      color: var(--foreground);

      @media (min-width: 640px) {
        font-size: 1.875rem;
      }
    }
  }

  .docs-nav {
    display: flex;
    align-items: center;
    gap: calc(var(--spacing) * 2);
    flex-shrink: 0;
  }

  .copy-page-group {
    background-color: var(--secondary);
    border-radius: var(--radius);
    display: none;
    position: relative;
    align-items: center;

    @media (min-width: 40rem) {
      display: flex;
    }
  }

  .copy-page-separator {
    width: 1px;
    height: 1rem;
    background-color: var(--border);
  }

  .ai-services-menu {
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: 0.25rem;
    z-index: 50;
    min-width: 12rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background-color: var(--popover-background, var(--background));
    box-shadow: var(--shadow-md);
    opacity: 0;
    pointer-events: none;
    transform: scale(0.95);
    transform-origin: top right;
    transition:
      opacity 100ms ease-out,
      transform 100ms ease-out;
  }

  .ai-services-menu.open {
    opacity: 1;
    pointer-events: auto;
    transform: scale(1);
  }

  .ai-services-content {
    display: flex;
    flex-direction: column;
    padding: calc(var(--spacing) * 0.5);
    gap: 0;
  }

  .ai-service-item {
    display: flex;
    align-items: center;
    gap: calc(var(--spacing) * 2);
    padding: calc(var(--spacing) * 1.5) calc(var(--spacing) * 2);
    border-radius: calc(var(--radius) * 0.75);
    font-size: 0.875rem;
    line-height: 1.25rem;
    color: var(--foreground);
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 100ms;

    &:hover {
      background-color: var(--accent);
      color: var(--accent-foreground);
    }

    :global(svg) {
      width: 1rem;
      height: 1rem;
      flex-shrink: 0;
      color: var(--muted-foreground);
    }
  }

  .nav-buttons {
    display: flex;
    gap: calc(var(--spacing) * 2);
    margin-left: auto;
  }

  .doc-title-description {
    margin: 0;
    color: var(--muted-foreground);
    font-size: 1rem;
    line-height: 1.75rem;
    text-wrap: balance;

    @media (min-width: 640px) {
      max-width: 80%;
    }
  }
</style>
